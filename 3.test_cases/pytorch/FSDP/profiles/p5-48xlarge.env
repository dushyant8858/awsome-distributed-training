# p5.48xlarge — 8x H100 80GB, 32 EFA, NVLink, GPUDirect RDMA
# All models in models/ work as-is.
#
# Validated with: Llama 3.1 8B, Llama 2 70B, Mixtral 8x7B on 4 nodes
#
# MODEL NOTES:
#   All 9 model configs run on p5 without changes. Same as p5en but
#   with 80 GB VRAM instead of 141 GB — still sufficient for all models.

# --- Hardware ---
export GPUS_PER_NODE=8

# --- EFA / NCCL ---
export FI_PROVIDER=efa
export FI_EFA_USE_HUGE_PAGE=0
export FI_EFA_SET_CUDA_SYNC_MEMOPS=0
export NCCL_SOCKET_IFNAME="^docker,lo,veth,eth"

# --- Kubernetes resource requests ---
export GPU_PER_NODE=8
export EFA_PER_NODE=32

# --- FSDP training overrides ---
export FSDP_CPU_OFFLOAD=0
